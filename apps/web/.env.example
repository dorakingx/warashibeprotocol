# Copy to `.env.local` for local dev (never commit real secrets).

# --- Agent LLM (pick one provider) ---
# Groq — recommended: free tier, OpenAI-compatible OSS models (see console.groq.com/docs/models).
GROQ_API_KEY=
# Optional override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — used only if GROQ_API_KEY is unset
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Agent request timeout (ms)
# AGENT_LLM_TIMEOUT_MS=20000

# --- Chain / Frame ---
# Ethereum Sepolia (L1 testnet, chain ID 11155111):
# NEXT_PUBLIC_CHAIN_ID=11155111
# NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia.publicnode.com
# RPC_URL=https://ethereum-sepolia.publicnode.com
# Deploy contracts with forge, then set addresses below:
# cd packages/contracts && forge script script/Deploy.s.sol:DeployScript \
#   --rpc-url https://ethereum-sepolia.publicnode.com --broadcast
# (Fund `ETH_FROM` / default broadcaster with Sepolia ETH; `--private-key` if needed.)
# NEXT_PUBLIC_ESCROW_ADDRESS=
# NEXT_PUBLIC_STRAW_NFT_ADDRESS=
#
# Base Sepolia example:
# NEXT_PUBLIC_CHAIN_ID=84532
# NEXT_PUBLIC_RPC_URL=https://...
#
# Local Anvil — use chain 1337 for MetaMask (31337 is listed as GoChain Testnet / GO on chain lists):
# anvil --chain-id 1337
# NEXT_PUBLIC_CHAIN_ID=1337
# NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
# RPC_URL=http://127.0.0.1:8545
# NEXT_PUBLIC_ESCROW_ADDRESS=
# NEXT_PUBLIC_STRAW_NFT_ADDRESS=
# NEXT_PUBLIC_APP_URL=http://localhost:3000
